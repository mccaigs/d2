# Bidworx API environment
# Copy to .env for local development. Configure the same values in Railway for production.

# Application
APP_NAME=Bidworx API
APP_VERSION=1.0.0
DEBUG=false

# CORS
# Comma-separated origins that may call the FastAPI API directly.
# Keep local origins for development and add the production Vercel domain before launch.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3100,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:3100,https://bidworx.example,https://www.bidworx.example

# Allows Vercel preview deployments such as https://bidworx-git-feature-team.vercel.app.
# Leave blank to disable regex-based preview CORS.
CORS_ORIGIN_REGEX=^https://.*\.vercel\.app$

# Railway provides PORT automatically.
# For local development use:
HOST=0.0.0.0
PORT=8000
