# FastAPI backend — copy to .env for local development
# Railway injects these automatically in production; never commit real secrets.

# --- Application ---
DEBUG=false

# --- CORS ---
# Comma-separated list of allowed origins.
# In production set this on Railway to include your Vercel production URL
# and any preview URLs you need. The default code already allows localhost
# and https://davidrobertson.pro — only set this to OVERRIDE that list.
# CORS_ORIGINS=https://davidrobertson.pro,https://your-preview.vercel.app

# --- Server (local reference only) ---
# Railway supplies $PORT automatically; these values are only used locally.
PORT=8000
HOST=0.0.0.0
