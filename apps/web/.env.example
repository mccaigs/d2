# Bidworx web environment
# Copy to .env.local for local development. Configure production values in Vercel.

# Public site URL used for metadata.
NEXT_PUBLIC_SITE_URL=https://bidworx.example

# Browser-side API base URL.
# Local default: leave unset so the app calls /api and Next.js rewrites to FastAPI.
# Vercel option A: leave unset and set API_BASE_URL below to proxy through Next.js.
# Vercel option B: set this to the Railway API URL including /api for direct browser calls.
# NEXT_PUBLIC_API_BASE_URL=https://your-api.up.railway.app/api

# Server-side rewrite destination used by apps/web/next.config.ts.
# Set this on Vercel to the Railway service URL without /api.
API_BASE_URL=https://your-api.up.railway.app

# Contact form webhook.
# Optional for the tender analysis demo path. Required before enabling production enquiries.
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/REPLACE_WITH_YOUR_DEPLOYMENT_ID/exec
