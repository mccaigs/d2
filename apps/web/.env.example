# Local development
# The frontend calls `/api/...` and next.config.ts rewrites that to the
# FastAPI server below. Leave NEXT_PUBLIC_API_BASE_URL unset to use the
# rewrite (recommended for local dev).
#
# If you want the browser to talk directly to FastAPI (skipping the
# rewrite), set this to the FastAPI base URL, e.g.:
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
