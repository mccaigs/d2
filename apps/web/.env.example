# Next.js frontend — copy to .env.local for local development
# Vercel injects production/preview values from its dashboard; never commit real secrets.

# --- Backend API (browser-side) ---
# Leave UNSET locally to use the Next.js rewrite proxy (next.config.ts → localhost:8000).
# Set this on Vercel (Production + Preview) to your Railway service URL including /api:
# NEXT_PUBLIC_API_BASE_URL=https://your-api.up.railway.app/api

# --- Backend API (server-side rewrite destination) ---
# Used by next.config.ts rewrites on the server. Set to your Railway URL (no /api suffix).
# Leave UNSET locally; the default falls back to http://localhost:8000.
# API_BASE_URL=https://your-api.up.railway.app

# --- Contact form webhook (required in production) ---
# The Google Apps Script web app URL that receives contact form submissions.
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/REPLACE_WITH_YOUR_DEPLOYMENT_ID/exec
